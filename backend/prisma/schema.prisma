generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       String   @id @default(uuid())
  email    String   @unique
  password String
  firstName String @map("first_name")
  lastName String? @map("last_name")
  timezone String?
  creation DateTime @default(now())
  settings Json     @default("{\"the guy\": {\"last name\": \"guy\", \"first name\": \"might\"}}")
  habit    Habit[]

  isVerified Boolean @default(false) @map("is_verified")
  verificationCode String? @map("verification_code")
  codeExpires DateTime? @map("code_expires")

  friends User[] @relation("UserFriends")
  friendsOf User[] @relation("UserFriends")

  @@map("user")
}

model Habit {
  id            String         @id @default(uuid())
  userId        String         @map("user_id")
  name          String
  description   String?
  habitCategory HabitCategory  @map("habit_category")
  visibility    Boolean        @default(true)
  currentStreak Int            @default(0) @map("current_streak")
  priorityRank  Int?           @map("priority_rank")
  frequency     HabitFrequency
  active        Boolean        @default(true)
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  user          User           @relation(fields: [userId], references: [id])
  checkIns      HabitCheckIn[]

  @@map("habit")
}

model HabitCheckIn {
  id                String   @id @default(uuid())
  date              DateTime @default(now())
  habitId           String   @map("habit_id")
  completed         Boolean
  difficultyRating Int? @map("difficulty_rating")
  notes             String?
  habit             Habit    @relation(fields: [habitId], references: [id])

  @@map("habit_check_in")
}

enum HabitFrequency {
  DAILY
  WEEKLY
  MONTHLY
}

enum HabitCategory {
  FITNESS
  NUTRITION
  PRODUCTIVITY
  WELLNESS
  SLEEP
  OTHER
}
